{
  "name": "kod-backend",
  "version": "1.0.0",
  "description": "Standalone Backend API for KOD Battle Arena",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/scripts/run-migrations.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.1.0",
    "hono": "^4.5.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "fastify": "^5.10.0",
    "nodemon": "^3.1.4",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}
